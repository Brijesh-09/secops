<?xml version="1.0" encoding="UTF-8"?>
<!--
    settings.xml — Maven credentials file
    =======================================
    Lives in PROJECT ROOT, passed to Maven with: mvn -s settings.xml
    Credentials injected by Jenkins at runtime via -Djfrog.user and -Djfrog.apikey

    3 server IDs here — must match IDs in pom.xml:
      jfrog-virtual  → pulls 3rd party dependencies (repositories)
      jfrog-release  → pushes release artifacts (distributionManagement)
      jfrog-snapshot → pushes snapshot artifacts (distributionManagement)
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="
          http://maven.apache.org/SETTINGS/1.0.0
          https://maven.apache.org/xsd/settings-1.0.0.xsd">

    <servers>

        <!-- Virtual repo — used for PULLING 3rd party dependencies -->
        <server>
            <id>jfrog-virtual</id>
            <username>${jfrog.user}</username>
            <password>${jfrog.apikey}</password>
        </server>

        <!-- Release repo — used for PUSHING release builds -->
        <server>
            <id>jfrog-release</id>
            <username>${jfrog.user}</username>
            <password>${jfrog.apikey}</password>
        </server>

        <!-- Snapshot repo — used for PUSHING snapshot builds -->
        <server>
            <id>jfrog-snapshot</id>
            <username>${jfrog.user}</username>
            <password>${jfrog.apikey}</password>
        </server>

    </servers>

</settings>