<?xml version="1.0" encoding="UTF-8"?>

<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4-0-0.xsd">

    <!-- =====================================================
         BASIC PROJECT INFORMATION
         ===================================================== -->
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.mycompany</groupId>
    <artifactId>my-app</artifactId>

    <!-- SNAPSHOT = development build -->
    <version>1.0.0-SNAPSHOT</version>

    <packaging>jar</packaging>
    <name>My DevSecOps App</name>

    <!-- =====================================================
         GLOBAL PROPERTIES
         ===================================================== -->
    <properties>

        <!-- Java -->
        <java.version>17</java.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>

        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- SonarCloud -->
        <sonar.projectKey>brijesh-secops</sonar.projectKey>
        <sonar.organization>brijesh-secops_scanner</sonar.organization>
        <sonar.host.url>https://sonarcloud.io</sonar.host.url>

        <!-- JaCoCo coverage report -->
        <sonar.coverage.jacoco.xmlReportPaths>
            target/site/jacoco/jacoco.xml
        </sonar.coverage.jacoco.xmlReportPaths>

        <!-- Base JFrog URL ONLY -->
        <!-- Jenkins overrides this -->
        <jfrog.url>
            https://trialxcztq9.jfrog.io/artifactory
        </jfrog.url>

    </properties>

    <!-- =====================================================
         DEPENDENCIES
         ===================================================== -->
    <dependencies>

        <!-- JUnit 5 -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.10.0</version>
            <scope>test</scope>
        </dependency>

        <!-- Logging -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-simple</artifactId>
            <version>2.0.9</version>
        </dependency>

    </dependencies>

    <!-- =====================================================
         REPOSITORIES
         WHERE MAVEN DOWNLOADS DEPENDENCIES FROM
         ===================================================== -->
    <repositories>

        <!-- RELEASE REPOSITORY -->
        <repository>
            <id>jfrog-release</id>

            <name>JFrog Release Repository</name>

            <url>
                ${jfrog.url}/api/maven/secops-pipeline-libs-release-local
            </url>

            <releases>
                <enabled>true</enabled>
            </releases>

            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </repository>

        <!-- SNAPSHOT REPOSITORY -->
        <repository>
            <id>jfrog-snapshot</id>

            <name>JFrog Snapshot Repository</name>

            <url>
                ${jfrog.url}/api/maven/secops-pipeline-libs-snapshot-local
            </url>

            <releases>
                <enabled>false</enabled>
            </releases>

            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>

    </repositories>

    <!-- =====================================================
         DEPLOYMENT TARGETS
         WHERE MAVEN UPLOADS ARTIFACTS
         ===================================================== -->
    <distributionManagement>

        <!-- RELEASE DEPLOYMENT -->
        <repository>
            <id>jfrog-release</id>

            <name>JFrog Release Deployment</name>

            <url>
                ${jfrog.url}/api/maven/secops-pipeline-libs-release-local
            </url>
        </repository>

        <!-- SNAPSHOT DEPLOYMENT -->
        <snapshotRepository>
            <id>jfrog-snapshot</id>

            <name>JFrog Snapshot Deployment</name>

            <url>
                ${jfrog.url}/api/maven/secops-pipeline-libs-snapshot-local
            </url>
        </snapshotRepository>

    </distributionManagement>

    <!-- =====================================================
         BUILD CONFIGURATION
         ===================================================== -->
    <build>

        <plugins>

            <!-- =========================================
                 JAVA COMPILER
                 ========================================= -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>

                <artifactId>maven-compiler-plugin</artifactId>

                <version>3.11.0</version>

                <configuration>
                    <source>17</source>
                    <target>17</target>
                </configuration>
            </plugin>

            <!-- =========================================
                 UNIT TESTS
                 ========================================= -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>

                <artifactId>maven-surefire-plugin</artifactId>

                <version>3.1.2</version>
            </plugin>

            <!-- =========================================
                 JACOCO COVERAGE
                 ========================================= -->
            <plugin>
                <groupId>org.jacoco</groupId>

                <artifactId>jacoco-maven-plugin</artifactId>

                <version>0.8.11</version>

                <executions>

                    <!-- Attach coverage agent -->
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>

                    <!-- Generate XML report -->
                    <execution>
                        <id>report</id>

                        <phase>test</phase>

                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>

                </executions>
            </plugin>

            <!-- =========================================
                 SONARCLOUD SCANNER
                 ========================================= -->
            <plugin>
                <groupId>org.sonarsource.scanner.maven</groupId>

                <artifactId>sonar-maven-plugin</artifactId>

                <version>3.10.0.2594</version>
            </plugin>

            <!-- =========================================
                 MAVEN DEPLOY PLUGIN
                 Uploads artifact to JFrog
                 ========================================= -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>

                <artifactId>maven-deploy-plugin</artifactId>

                <version>3.1.1</version>
            </plugin>

        </plugins>

    </build>

</project>